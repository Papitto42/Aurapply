# AurApply Backend Environment Variables
# Copy this file to .env and update with your actual values
# Command: cp env.template .env

# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Configuration
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/aurapply

# Option 2: MongoDB Atlas (uncomment and update)
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aurapply?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=SECRET_KEY_CHANGE_IN_PRODUCTION
JWT_EXPIRES_IN=24h

# CORS Configuration
# Frontend URL - update if your frontend runs on a different port
CORS_ORIGIN=http://localhost:3000

# Google Gemini Configuration (FREE - Recommended!)
# Get your FREE API key from https://aistudio.google.com/app/apikey
# Google Gemini has a generous free tier - perfect for this app!
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Configuration (Optional - if you prefer OpenAI over Gemini)
# Get your API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

